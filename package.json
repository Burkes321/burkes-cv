{
  "name": "samuel-burke-cv",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tailwindcss -i styles.css -o public/output.css --minify",
    "watch:css": "tailwindcss -i styles.css -o public/output.css --watch",
    "serve": "live-server public --port=8080",
    "dev": "concurrently \"npm run watch:css\" \"npm run serve\""
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "concurrently": "^10.0.3",
    "live-server": "^1.2.2",
    "tailwindcss": "^4.0.0"
  }
}
